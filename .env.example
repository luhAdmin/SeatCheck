# Copy this file to `.env` and fill in the three values from your app registration.
# See APP_REGISTRATION_GUIDE.md for how to get these.

TENANT_ID=00000000-0000-0000-0000-000000000000
CLIENT_ID=00000000-0000-0000-0000-000000000000
CLIENT_SECRET=your-secret-value-here

# Friendly name that appears at the top of the PDF report
TENANT_NAME=Acme Corporation
